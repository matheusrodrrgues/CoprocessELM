// =============================================================================
// TESTBENCH COMPLETO - elm_accel (coprocessador MLP MNIST)
// =============================================================================
// Cobre:
//   1. Reset e estado inicial
//   2. CMD_STORE_IMG via Avalon (escrita de pixel na mem_imagem)
//   3. CMD_STORE_W   via Avalon (escrita de peso  na mem_pesos)
//   4. CMD_STORE_B   via Avalon (escrita de bias  na mem_bias)
//   5. CMD_STATUS    (leitura do registrador de status)
//   6. CMD_START sem dados carregados  → deve ir para ST_ERROR
//   7. CMD_CLEAR_ERR → volta para ST_IDLE
//   8. Carga completa via Avalon + CMD_START → aguarda ST_DONE
//   9. Verificação da predição final e flags nos LEDs
//  10. Leitura Avalon dos registradores 0x3, 0x4 e 0x5
//  11. Segundo CMD_START a partir de ST_DONE (re-inferência)
//  12. Exibição dos displays HEX em cada fase
// =============================================================================
`timescale 1ns / 1ps

module tb_elm_accel_completo;

    // -------------------------------------------------------------------------
    // Parâmetros do DUT
    // -------------------------------------------------------------------------
    localparam integer D        = 784;
    localparam integer H        = 128;
    localparam integer C        = 10;
    localparam integer DATA_W   = 16;
    localparam integer ACC_W    = 32;
    localparam integer Q_FRAC   = 12;
    localparam integer CLK_HZ   = 50000000;
    localparam integer IMG_BIN_TH = 1536;

    // Opcodes (devem bater com os do DUT)
    localparam [2:0] CMD_CLEAR_ERR = 3'd0;
    localparam [2:0] CMD_STORE_IMG = 3'd1;
    localparam [2:0] CMD_STORE_W   = 3'd2;
    localparam [2:0] CMD_STORE_B   = 3'd3;
    localparam [2:0] CMD_START     = 3'd4;
    localparam [2:0] CMD_STATUS    = 3'd5;

    // Estados (devem bater com os do DUT)
    localparam [1:0] ST_IDLE  = 2'b00;
    localparam [1:0] ST_BUSY  = 2'b01;
    localparam [1:0] ST_DONE  = 2'b10;
    localparam [1:0] ST_ERROR = 2'b11;

    // Período de clock: 20 ns = 50 MHz
    localparam CLK_PERIOD = 20;

    // -------------------------------------------------------------------------
    // Sinais
    // -------------------------------------------------------------------------
    reg         clk;
    reg         reset_n;

    // Interface switches / botões (coprocessador)
    reg  [31:0] sw;
    reg         confirm_btn;
    reg         prep_btn;

    // Interface Avalon-MM
    reg  [3:0]  avs_address;
    reg         avs_write;
    reg  [31:0] avs_writedata;
    reg         avs_read;
    wire [31:0] avs_readdata;
    wire        avs_waitrequest;

    // Saídas
    wire [31:0] result_out;
    wire [6:0]  hex3, hex2, hex1, hex0;
    wire [3:0]  ledr_pred;
    wire [2:0]  ledr_flags;

    // Contadores e controle do TB
    integer    erro_count;
    integer    ok_count;
    integer    i;

    // -------------------------------------------------------------------------
    // Instância do DUT
    // -------------------------------------------------------------------------
    elm_accel #(
        .D          (D),
        .H          (H),
        .C          (C),
        .DATA_W     (DATA_W),
        .ACC_W      (ACC_W),
        .Q_FRAC     (Q_FRAC),
        .CLK_HZ     (CLK_HZ),
        .STATUS_ON_SECONDS(10),
        .IMG_BIN_TH (IMG_BIN_TH)
    ) dut (
        .clk            (clk),
        .reset_n        (reset_n),
        .sw             (sw),
        .confirm_btn    (confirm_btn),
        .prep_btn       (prep_btn),
        .result_out     (result_out),
        .avs_address    (avs_address),
        .avs_write      (avs_write),
        .avs_writedata  (avs_writedata),
        .avs_read       (avs_read),
        .avs_readdata   (avs_readdata),
        .avs_waitrequest(avs_waitrequest),
        .hex3           (hex3),
        .hex2           (hex2),
        .hex1           (hex1),
        .hex0           (hex0),
        .ledr_pred      (ledr_pred),
        .ledr_flags     (ledr_flags)
    );

    // -------------------------------------------------------------------------
    // Clock
    // -------------------------------------------------------------------------
    initial clk = 0;
    always #(CLK_PERIOD/2) clk = ~clk;

    // -------------------------------------------------------------------------
    // Tarefas auxiliares
    // -------------------------------------------------------------------------

    // Aguarda N ciclos de clock
    task wait_cycles;
        input integer n;
        integer k;
        begin
            for (k = 0; k < n; k = k + 1)
                @(posedge clk);
        end
    endtask

    // Produz um pulso de 1 ciclo em confirm_btn
    task pulso_confirm;
        begin
            @(posedge clk);
            #1 confirm_btn = 1;
            @(posedge clk);
            #1 confirm_btn = 0;
            @(posedge clk);
        end
    endtask

    // Produz um pulso de 1 ciclo em prep_btn
    task pulso_prep;
        begin
            @(posedge clk);
            #1 prep_btn = 1;
            @(posedge clk);
            #1 prep_btn = 0;
            @(posedge clk);
        end
    endtask

    // Escrita Avalon (1 ciclo)
    task avalon_write;
        input [3:0]  addr;
        input [31:0] data;
        begin
            @(posedge clk);
            #1;
            avs_address   = addr;
            avs_writedata = data;
            avs_write     = 1;
            @(posedge clk);
            #1;
            avs_write     = 0;
            avs_address   = 0;
            avs_writedata = 0;
            @(posedge clk);
        end
    endtask

    // Leitura Avalon (1 ciclo) → retorna em avs_readdata
    task avalon_read;
        input [3:0] addr;
        begin
            @(posedge clk);
            #1;
            avs_address = addr;
            avs_read    = 1;
            @(posedge clk);
            #1;
            avs_read    = 0;
            avs_address = 0;
            @(posedge clk);
        end
    endtask

    // Verifica condição — registra PASS/FAIL
    task check;
        input [127:0] descricao;
        input         condicao;
        begin
            if (condicao) begin
                $display("[PASS] %s", descricao);
                ok_count = ok_count + 1;
            end else begin
                $display("[FAIL] %s  (result_out=%08h  ledr_pred=%0d  ledr_flags=%b)",
                          descricao, result_out, ledr_pred, ledr_flags);
                erro_count = erro_count + 1;
            end
        end
    endtask

    // Imprime estado dos displays para visualização
    task mostra_display;
        input [127:0] label;
        begin
            $display("  [DISP %s]  HEX3=%07b HEX2=%07b HEX1=%07b HEX0=%07b",
                      label, hex3, hex2, hex1, hex0);
        end
    endtask

    // =========================================================================
    // CENÁRIO PRINCIPAL
    // =========================================================================
    initial begin
        // -------------------------------------------------------------------
        // Inicialização
        // -------------------------------------------------------------------
        erro_count    = 0;
        ok_count      = 0;

        reset_n       = 0;
        sw            = 32'h0;
        confirm_btn   = 0;
        prep_btn      = 0;
        avs_address   = 4'h0;
        avs_write     = 0;
        avs_writedata = 32'h0;
        avs_read      = 0;

        $display("=================================================================");
        $display("  TESTBENCH COMPLETO - elm_accel / coprocessador MNIST MLP");
        $display("=================================================================");

        // -------------------------------------------------------------------
        // TESTE 1 — Reset
        // -------------------------------------------------------------------
        $display("\n--- TESTE 1: Reset ativo ---");
        wait_cycles(5);
        reset_n = 1;
        wait_cycles(3);

        check("Após reset: estado IDLE (bits [11:10]=00)",
              result_out[11:10] == ST_IDLE);
        check("Após reset: sem imagem carregada (bit 9=0)",
              result_out[9] == 1'b0);
        check("Após reset: sem pesos carregados (bit 8=0)",
              result_out[8] == 1'b0);
        check("Após reset: sem bias carregado  (bit 7=0)",
              result_out[7] == 1'b0);
        check("Após reset: não está em execução (bit 4=0)",
              result_out[4] == 1'b0);
        check("Após reset: não finalizado (bit 5=0)",
              result_out[5] == 1'b0);
        check("Após reset: sem erro (bit 6=0)",
              result_out[6] == 1'b0);

        mostra_display("IDLE");

        // -------------------------------------------------------------------
        // TESTE 2 — CMD_STATUS (sem dados) via botão
        // -------------------------------------------------------------------
        $display("\n--- TESTE 2: CMD_STATUS via botão (sem dados) ---");
        sw = {29'd0, CMD_STATUS};
        pulso_confirm;
        wait_cycles(2);

        check("CMD_STATUS mantém ST_IDLE", result_out[11:10] == ST_IDLE);
        mostra_display("IDLE");

        // -------------------------------------------------------------------
        // TESTE 3 — CMD_START sem dados → ST_ERROR
        // -------------------------------------------------------------------
        $display("\n--- TESTE 3: CMD_START sem dados → ST_ERROR ---");
        sw = {29'd0, CMD_START};
        pulso_confirm;
        wait_cycles(5);

        check("CMD_START sem dados → ST_ERROR (bits [11:10]=11)",
              result_out[11:10] == ST_ERROR);
        check("Flag de erro ativo (bit 6=1)",
              result_out[6] == 1'b1);

        mostra_display("ERRO");

        // -------------------------------------------------------------------
        // TESTE 4 — CMD_CLEAR_ERR → volta para ST_IDLE
        // -------------------------------------------------------------------
        $display("\n--- TESTE 4: CMD_CLEAR_ERR → ST_IDLE ---");
        sw = {29'd0, CMD_CLEAR_ERR};
        pulso_confirm;
        wait_cycles(3);

        check("CMD_CLEAR_ERR → ST_IDLE", result_out[11:10] == ST_IDLE);
        check("Flag de erro limpa", result_out[6] == 1'b0);

        mostra_display("IDLE");

        // -------------------------------------------------------------------
        // TESTE 5 — Escrita de 1 pixel via Avalon (addr=0x0)
        //   writedata[25:16] = endereço (10 bits)
        //   writedata[15:0]  = valor Q4.12
        // -------------------------------------------------------------------
        $display("\n--- TESTE 5: Escrita de pixel via Avalon ---");
        // Pixel 0 = valor 2048 (= 0.5 em Q4.12, acima do limiar 1536 → binariza para 4095)
        avalon_write(4'h0, {6'd0, 10'd0, 16'sd2048});
        wait_cycles(2);

        check("Após write Avalon img: estado ainda IDLE",
              result_out[11:10] == ST_IDLE);

        // -------------------------------------------------------------------
        // TESTE 6 — CMD_STORE_IMG via botão confirma a escrita
        // -------------------------------------------------------------------
        $display("\n--- TESTE 6: CMD_STORE_IMG via botão ---");
        sw = {29'd0, CMD_STORE_IMG};
        pulso_confirm;
        wait_cycles(5);

        check("Após CMD_STORE_IMG: volta a ST_IDLE",
              result_out[11:10] == ST_IDLE);
        check("Flag imagem_ok ativo (bit 9=1)",
              result_out[9] == 1'b1);
        check("LEDR_flags[2] = imagem_ok",
              ledr_flags[2] == 1'b1);

        // -------------------------------------------------------------------
        // TESTE 7 — Escrita de um peso via Avalon (addr=0x1)
        //   writedata[28:12] = endereço (17 bits)
        //   writedata[15:0]  = valor Q4.12
        // -------------------------------------------------------------------
        $display("\n--- TESTE 7: Escrita de peso via Avalon ---");
        // Peso endereço 0 = 1024 (= 0.25 em Q4.12)
        avalon_write(4'h1, {3'd0, 17'd0, 16'sd1024});
        wait_cycles(2);

        sw = {29'd0, CMD_STORE_W};
        pulso_confirm;
        wait_cycles(5);

        check("Após CMD_STORE_W: volta a ST_IDLE",
              result_out[11:10] == ST_IDLE);
        check("Flag pesos_ok ativo (bit 8=1)",
              result_out[8] == 1'b1);
        check("LEDR_flags[1] = pesos_ok",
              ledr_flags[1] == 1'b1);

        // -------------------------------------------------------------------
        // TESTE 8 — Escrita de bias via Avalon (addr=0x2)
        //   writedata[22:16] = endereço (7 bits)
        //   writedata[15:0]  = valor Q4.12
        // -------------------------------------------------------------------
        $display("\n--- TESTE 8: Escrita de bias via Avalon ---");
        // Bias endereço 0 = 512 (= 0.125 em Q4.12)
        avalon_write(4'h2, {9'd0, 7'd0, 16'sd512});
        wait_cycles(2);

        sw = {29'd0, CMD_STORE_B};
        pulso_confirm;
        wait_cycles(5);

        check("Após CMD_STORE_B: volta a ST_IDLE",
              result_out[11:10] == ST_IDLE);
        check("Flag bias_ok ativo (bit 7=1)",
              result_out[7] == 1'b1);
        check("LEDR_flags[0] = bias_ok",
              ledr_flags[0] == 1'b1);

        // -------------------------------------------------------------------
        // TESTE 9 — Leitura Avalon do registrador de status (0x3)
        // -------------------------------------------------------------------
        $display("\n--- TESTE 9: Leitura Avalon status (0x3) ---");
        avalon_read(4'h3);
        wait_cycles(2);

        check("Leitura Avalon 0x3: imagem_ok=1 (bit 9)",
              avs_readdata[9] == 1'b1);
        check("Leitura Avalon 0x3: pesos_ok=1 (bit 8)",
              avs_readdata[8] == 1'b1);
        check("Leitura Avalon 0x3: bias_ok=1  (bit 7)",
              avs_readdata[7] == 1'b1);
        check("Leitura Avalon 0x3: não em erro (bit 6=0)",
              avs_readdata[6] == 1'b0);

        $display("  status Avalon = 0x%08h", avs_readdata);

        // -------------------------------------------------------------------
        // TESTE 10 — CMD_START com todos os dados → inferência completa
        // -------------------------------------------------------------------
        $display("\n--- TESTE 10: CMD_START com dados → ST_BUSY → ST_DONE ---");
        sw = {29'd0, CMD_START};
        pulso_confirm;

        // Aguarda sair de IDLE (entrar em BUSY)
        wait_cycles(3);
        check("Após CMD_START: em ST_BUSY (bits [11:10]=01)",
              result_out[11:10] == ST_BUSY);
        check("Bit busy ativo (bit 4=1)",
              result_out[4] == 1'b1);

        mostra_display("BUSY");

        // Aguarda a inferência terminar (ST_DONE)
        // D=784, H=128, C=10 → muitos ciclos; usamos timeout
        begin : espera_done
            integer timeout;
            timeout = 0;
            while ((result_out[11:10] !== ST_DONE) && (timeout < 2_000_000)) begin
                @(posedge clk);
                timeout = timeout + 1;
            end
            if (timeout >= 2_000_000)
                $display("[AVISO] Timeout esperando ST_DONE!");
        end

        wait_cycles(5);

        check("Inferência completa: ST_DONE (bits [11:10]=10)",
              result_out[11:10] == ST_DONE);
        check("Bit done ativo (bit 5=1)",
              result_out[5] == 1'b1);
        check("Bit busy inativo (bit 4=0)",
              result_out[4] == 1'b0);
        check("Predição válida: 0 a 9",
              ledr_pred <= 4'd9);

        mostra_display("DONE");

        $display("  >>> Dígito previsto = %0d <<<", ledr_pred);
        $display("  result_out = 0x%08h", result_out);

        // -------------------------------------------------------------------
        // TESTE 11 — Leitura Avalon da predição (0x4) e ciclos (0x5)
        // -------------------------------------------------------------------
        $display("\n--- TESTE 11: Leitura Avalon predição (0x4) e ciclos (0x5) ---");
        avalon_read(4'h4);
        wait_cycles(2);
        check("Leitura Avalon 0x4: predição bate com ledr_pred",
              avs_readdata[3:0] == ledr_pred);
        $display("  Predição via Avalon = %0d", avs_readdata[3:0]);

        avalon_read(4'h5);
        wait_cycles(2);
        check("Leitura Avalon 0x5: ciclos > 0",
              avs_readdata > 32'd0);
        $display("  Ciclos de execução  = %0d", avs_readdata);

        // -------------------------------------------------------------------
        // TESTE 12 — Segundo CMD_START a partir de ST_DONE (re-inferência)
        // -------------------------------------------------------------------
        $display("\n--- TESTE 12: Re-inferência a partir de ST_DONE ---");
        sw = {29'd0, CMD_START};
        pulso_confirm;

        wait_cycles(3);
        check("Após 2° CMD_START: em ST_BUSY",
              result_out[11:10] == ST_BUSY);

        begin : espera_done2
            integer timeout2;
            timeout2 = 0;
            while ((result_out[11:10] !== ST_DONE) && (timeout2 < 2_000_000)) begin
                @(posedge clk);
                timeout2 = timeout2 + 1;
            end
            if (timeout2 >= 2_000_000)
                $display("[AVISO] Timeout esperando ST_DONE (2a inferência)!");
        end

        wait_cycles(5);
        check("2a inferência: ST_DONE",
              result_out[11:10] == ST_DONE);
        check("2a predição = mesma da 1a (dados inalterados)",
              ledr_pred <= 4'd9);

        mostra_display("DONE2");
        $display("  >>> 2° Dígito previsto = %0d <<<", ledr_pred);

        // -------------------------------------------------------------------
        // TESTE 13 — CMD_CLEAR_ERR a partir de ST_DONE → ST_IDLE
        // -------------------------------------------------------------------
        $display("\n--- TESTE 13: CMD_CLEAR_ERR de ST_DONE → ST_IDLE ---");
        sw = {29'd0, CMD_CLEAR_ERR};
        pulso_confirm;
        wait_cycles(3);

        check("CMD_CLEAR_ERR de ST_DONE → ST_IDLE",
              result_out[11:10] == ST_IDLE);
        check("Flags preservadas após clear (imagem_ok=1)",
              result_out[9] == 1'b1);

        mostra_display("IDLE2");

        // -------------------------------------------------------------------
        // TESTE 14 — Forçar ST_ERROR de ST_DONE (limpar flags e tentar START)
        // -------------------------------------------------------------------
        $display("\n--- TESTE 14: Reset parcial e CMD_START sem flags → ST_ERROR ---");
        reset_n = 0;
        wait_cycles(3);
        reset_n = 1;
        wait_cycles(3);

        check("Após reset: flags zeradas", result_out[9:7] == 3'b000);

        sw = {29'd0, CMD_START};
        pulso_confirm;
        wait_cycles(5);

        check("CMD_START sem flags → ST_ERROR",
              result_out[11:10] == ST_ERROR);

        sw = {29'd0, CMD_CLEAR_ERR};
        pulso_confirm;
        wait_cycles(3);

        check("CMD_CLEAR_ERR limpa erro → ST_IDLE",
              result_out[11:10] == ST_IDLE);

        // -------------------------------------------------------------------
        // RESULTADO FINAL
        // -------------------------------------------------------------------
        $display("\n=================================================================");
        $display("  RESULTADO FINAL: %0d PASS  /  %0d FAIL", ok_count, erro_count);
        $display("=================================================================");

        if (erro_count == 0)
            $display("  *** TODOS OS TESTES PASSARAM ***");
        else
            $display("  *** ATENCAO: %0d TESTE(S) FALHARAM ***", erro_count);

        #100;
        $stop;
    end

    // -------------------------------------------------------------------------
    // Monitor contínuo de mudanças de estado (para o professor ver no log)
    // -------------------------------------------------------------------------
    reg [1:0] ultimo_estado;
    initial ultimo_estado = 2'bxx;

    always @(posedge clk) begin
        if (result_out[11:10] !== ultimo_estado) begin
            ultimo_estado <= result_out[11:10];
            case (result_out[11:10])
                ST_IDLE:  $display("  [MONITOR] @ %0t ns  → Estado: IDLE",  $time);
                ST_BUSY:  $display("  [MONITOR] @ %0t ns  → Estado: BUSY",  $time);
                ST_DONE:  $display("  [MONITOR] @ %0t ns  → Estado: DONE  pred=%0d", $time, result_out[3:0]);
                ST_ERROR: $display("  [MONITOR] @ %0t ns  → Estado: ERROR", $time);
            endcase
        end
    end

    // -------------------------------------------------------------------------
    // Geração de VCD (opcional para GTKWave)
    // -------------------------------------------------------------------------
    initial begin
        $dumpfile("tb_elm_accel_completo.vcd");
        $dumpvars(0, tb_elm_accel_completo);
    end

endmodule